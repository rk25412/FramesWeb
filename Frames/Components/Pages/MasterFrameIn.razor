@page "/master-frames-in"
<PageTitle>Master Frame In</PageTitle>

<h4 class="d-flex justify-content-between align-items-center">
    <span>Master Frame In</span>
    <span>
        <RadzenDropDown @bind-Value="@_selectedMonth"
                        Data="@_monthDropdown"
                        TValue="int"
                        TextProperty="Text"
                        ValueProperty="Value"
                        class="mx-1 mt-2"
                        Change="@MonthYearDropdownChanged"/>
        <RadzenDropDown @bind-Value="@_selectedYear"
                        Data="@_yearDropdown"
                        TValue="int"
                        TextProperty="Text"
                        ValueProperty="Value"
                        class="mx-1 mt-2"
                        Change="@MonthYearDropdownChanged"/>
        @if (_frameInlist.Count > 0)
        {
            <RadzenButton Text="Add Record"
                          class="float-end mt-2"
                          Click="@(() => OnAddUpdateMasterInClick())"/>
        }
    </span>
</h4>

@if (_frameInlist.Count is 0)
{
    <div class="text-center mt-5">
        <p class="text-center">
            No Records Found
        </p>
        <RadzenButton Text="Add Record"
                      Click="@(() => OnAddUpdateMasterInClick())"/>
    </div>
}
else
{
    <div class="mt-5">
        <div class="mb-3">
            <PageSummary HeaderTitle="This Month So Far">
                <div class="row">
                    <div class="col-6 text-end">
                        <strong>Total:</strong>
                    </div>
                    <div class="col-6 text-start">
                        <strong>
                            @TotalFrameCount
                        </strong>
                    </div>
                </div>
            </PageSummary>
        </div>

        <RadzenDataGrid @ref="@_grid0"
                        AllowFiltering="@false"
                        AllowSorting="@true"
                        AllowPaging="@false"
                        ColumnWidth="100px"
                        Data="@_frameInlist">
            <Columns>
                <RadzenDataGridColumn Title="Action"
                                      Frozen="@true"
                                      Sortable="@false"
                                      TextAlign="@TextAlign.Center">
                    <Template Context="data">
                        <RadzenButton ButtonType="@ButtonType.Button"
                                      Size="@ButtonSize.Medium"
                                      ButtonStyle="@ButtonStyle.Warning"
                                      Icon="edit"
                                      Click="@(() => OnAddUpdateMasterInClick(data))"/>
                        <RadzenButton ButtonType="@ButtonType.Button"
                                      Size="@ButtonSize.Medium"
                                      ButtonStyle="@ButtonStyle.Danger"
                                      Icon="delete"
                                      Click="@(() => OnRemoveMasterInClick(data))"/>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Property="@nameof(FrameInDto.Date)"
                                      Title="Date"
                                      Sortable="true"
                                      TextAlign="TextAlign.Center"
                                      Frozen="true"/>
                <RadzenDataGridColumn Property="@nameof(FrameInDto.TotalCount)"
                                      Title="Total"
                                      Sortable="true"
                                      TextAlign="TextAlign.Center"
                                      Frozen="true">
                    <Template Context="data">
                        <strong>@data.TotalCount</strong>
                    </Template>
                </RadzenDataGridColumn>
                @foreach (var item in Enumerable.Range(0, _maxDataColCount))
                {
                    <RadzenDataGridColumn Title="@($"Round {item + 1}")" 
                                          TextAlign="TextAlign.Center"
                                          Sortable="false">
                        <Template Context="data">
                            @if (data is FrameInDto dto)
                            {
                                var lineItem = dto.ItemsCount < item + 1 ? null : dto.InItems[item];
                                @if (lineItem is not null)
                                {
                                    <span>@lineItem.Time</span>
                                    <br/>
                                    <strong>@lineItem.Count</strong>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            }
                        </Template>
                    </RadzenDataGridColumn>
                }
            </Columns>
        </RadzenDataGrid>
    </div>
}


